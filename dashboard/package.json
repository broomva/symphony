{
	"name": "symphony-dashboard",
	"private": true,
	"packageManager": "bun@1.3.1",
	"license": "Apache-2.0",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "dotenv -e .env.local -- turbo run dev --filter=@symphony/web",
		"build": "dotenv -e .env.local -- turbo run build",
		"format": "turbo run format",
		"lint": "turbo run lint",
		"test": "turbo run test",
		"test:unit": "turbo run test:unit",
		"test:types": "turbo run test:types",
		"db:generate": "dotenv -e .env.local -- bun --filter=@symphony/web run db:generate",
		"db:migrate": "dotenv -e .env.local -- bun --filter=@symphony/web run db:migrate",
		"start": "dotenv -e .env.local -- bun --filter=@symphony/web run start"
	},
	"devDependencies": {
		"dotenv-cli": "^8.0.0",
		"turbo": "^2.8.11"
	}
}
